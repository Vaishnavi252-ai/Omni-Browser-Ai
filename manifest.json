{
  "manifest_version": 3,
  "name": "OmniBrowser AI",
  "version": "1.0.0",
  "description": "On-Device Privacy-First Multi-Tab Semantic Search and RAG Engine via WebGPU.",
  "permissions": [
    "sidePanel",
    "tabs",
    "activeTab",
    "offscreen",
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/offscreen/index.html", "src/offscreen/offscreen.ts"],
      "matches": ["<all_urls>"]
    }
  ]
}

